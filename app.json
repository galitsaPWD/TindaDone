{
  "expo": {
    "name": "TindaDone",
    "slug": "tindadone",
    "version": "1.0.0",
    "description": "TindaDone: The ultimate productivity and inventory manager for small businesses.",
    "githubUrl": "https://github.com/Carlwyne-Dev/TindaDone",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tindadone",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.carlwyne.tindadone"
    },
    "android": {
      "package": "com.carlwyne.tindadone",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "aab8cc38-461d-4098-8a53-5263d78f2fa6"
      },
      "router": {}
    },
    "owner": "wanaaaa"
  }
}
